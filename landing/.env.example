# SoulSquad Landing Site Environment Variables

# Railway backend URL (where opensoul server runs)
NEXT_PUBLIC_API_URL=https://api.soulsquad.ai

# App URL (this Vercel deployment)
NEXT_PUBLIC_APP_URL=https://soulsquad.ai

# Google OAuth (configured in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# better-auth secret (must match Railway backend)
BETTER_AUTH_SECRET=your-shared-secret
